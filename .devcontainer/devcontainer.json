{
  "_comment": "Added -U to ensure it upgrades if a cached version is old",
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.vscode-yaml",
        "keesschollaart.vscode-home-assistant",
        "davidanson.vscode-markdownlint",
        "yzhang.markdown-all-in-one",
        "ms-python.python",
        "charliermarsh.ruff"
      ],
      "settings": {
        "_comment": "This helps VS Code find your imports correctly",
        "editor.formatOnSave": true,
        "extensions.verifySignature": false,
        "markdownlint.config": {
          "MD013": false,
          "MD033": false
        },
        "python.analysis.extraPaths": [
          "/workspaces/${localWorkspaceFolderBasename}/custom_components"
        ],
        "yaml.schemas": {
          "https://raw.githubusercontent.com/hacs/default/master/hacs.json": "hacs.json",
          "https://raw.githubusercontent.com/home-assistant/schemas/main/frontend/lovelace_config.json": "ui-lovelace.yaml"
        },
        "yaml.validate": true
      }
    }
  },
  "dockerComposeFile": ["docker-compose.yml", "docker-compose.override.yml"],
  "mounts": [
    {
      "source": "vscode-server-vol-${localWorkspaceFolderBasename}",
      "target": "/root/.vscode-server",
      "type": "volume"
    }
  ],
  "name": "${localWorkspaceFolderBasename}",
  "overrideCommand": false,
  "postCreateCommand": "sed -i 's/\\r$//' .devcontainer/setup.sh && sh .devcontainer/setup.sh || (echo 'Setup failed! Check .reports/devcontainer/post_setup.log for details.' && sleep infinity)",
  "remoteUser": "root",
  "service": "homeassistant",
  "workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}"
}
