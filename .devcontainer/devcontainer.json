{
  "name": "WiFi SSID Monitor",
  "dockerComposeFile": "docker-compose.yml",
  "service": "homeassistant",
  "workspaceFolder": "/workspaces/ha-wifi-ssid-monitor",
  "_comment": "Added -U to ensure it upgrades if a cached version is old",
  "postCreateCommand": "pip install -r .validate/requirements_test.txt",
  "customizations": {
    "vscode": {
      "extensions": [
        "redhat.vscode-yaml",
        "keesschollaart.vscode-home-assistant",
        "davidanson.vscode-markdownlint",
        "yzhang.markdown-all-in-one",
        "ms-python.python",
        "charliermarsh.ruff"
      ],
      "settings": {
        "_comment": "This helps VS Code find your imports correctly",
        "python.analysis.extraPaths": [
          "/workspaces/ha-wifi-ssid-monitor/custom_components"
        ],
        "yaml.schemas": {
          "https://raw.githubusercontent.com/hacs/default/master/hacs.json": "hacs.json",
          "https://raw.githubusercontent.com/home-assistant/schemas/main/frontend/lovelace_config.json": "ui-lovelace.yaml"
        },
        "yaml.validate": true,
        "editor.formatOnSave": true,
        "markdownlint.config": {
          "MD013": false,
          "MD033": false
        }
      }
    }
  },
  "remoteUser": "root",
  "overrideCommand": false
}
